---
const BASE_URL = import.meta.env.BASE_URL;
---

<section class="hero">
  <!-- Interactive Floating Background -->
  <canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

  <div class="hero-inner">
    <div class="hero-left">
      <div class="status-bar">
        <span class="status-dot"></span>
        <span
          class="status-text font-mono"
        >
          SOEUK BONDOL — DATA SCIENTIST — CAMBODIA
        </span>
      </div>

      <h1 class="name">
        <span class="name-first">SOEUK</span>
        <span class="name-last">BONDOL<span class="name-cursor">.</span></span>
      </h1>

      <div class="role-row">
        <span class="role-tag">Data Science</span>
        <span class="role-sep">×</span>
        <span class="role-tag blue">Machine Learning</span>
        <span class="role-sep">×</span>
        <span class="role-tag violet">MLOps</span>
      </div>

      <p class="tagline">
        Turning raw data into decisions.<br />
        Building models that generalise, pipelines that scale,<br />
        and systems that actually ship.
      </p>

      <div class="cta-row">
        <a href="#projects" class="cta-primary">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
          View Projects
        </a>
        <a href="#contact" class="cta-ghost">Contact me</a>
        <a
          href="https://github.com/SoeukBondol-ai"
          target="_blank"
          rel="noopener"
          class="cta-icon"
          title="GitHub"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
            ></path></svg
          >
        </a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="panel-header">
        <div class="ph-dots"><span></span><span></span><span></span></div>
        <span class="ph-title font-mono">sys.profile()</span>
        <span class="ph-badge font-mono">LIVE</span>
      </div>
      <div class="panel-body">
        <div class="pb-row">
          <span class="pb-key">role</span><span class="pb-val amber"
            >Data Scientist</span
          >
        </div>
        <div class="pb-row">
          <span class="pb-key">location</span><span class="pb-val"
            >Phnom Penh, KH</span
          >
        </div>
        <div class="pb-row">
          <span class="pb-key">focus</span><span class="pb-val blue"
            >ML · CV · NLP</span
          >
        </div>
        <div class="pb-row">
          <span class="pb-key">lang</span><span class="pb-val amber"
            >Python</span
          >
        </div>
        <div class="pb-row"><span class="pb-row-sep"></span></div>
        <div class="pb-row">
          <span class="pb-key">projects</span><span class="pb-val font-mono" id="pCount"
            >0</span
          >
        </div>
        <div class="pb-row">
          <span class="pb-key">commits</span><span class="pb-val font-mono">∞</span>
        </div>
