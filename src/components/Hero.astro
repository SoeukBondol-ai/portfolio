          >
        </div>
        <div class="pb-row"><span class="pb-row-sep"></span></div>
        <div class="pb-chart-label font-mono">skill_index[]</div>
        <div class="pb-chart">
          <div class="pbc-item">
            <span class="pbc-l font-mono">Python</span>
            <div class="pbc-track">
              <div class="pbc-fill amber-fill" data-w="93"></div>
            </div>
            <span class="pbc-n font-mono">93</span>
          </div>
          <div class="pbc-item">
            <span class="pbc-l font-mono">ML/DL</span>
            <div class="pbc-track">
              <div class="pbc-fill cyan-fill" data-w="80"></div>
            </div>
            <span class="pbc-n font-mono">80</span>
          </div>
          <div class="pbc-item">
            <span class="pbc-l font-mono">SQL</span>
            <div class="pbc-track">
              <div class="pbc-fill" data-w="76"></div>
            </div>
            <span class="pbc-n font-mono">76</span>
          </div>
          <div class="pbc-item">
            <span class="pbc-l font-mono">DevOps</span>
            <div class="pbc-track">
              <div class="pbc-fill violet-fill" data-w="70"></div>
            </div>
            <span class="pbc-n font-mono">70</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="ticker">
    <div class="ticker-track">
      <span class="ta">DATA SCIENCE</span><span>·</span>
      <span>MACHINE LEARNING</span><span>·</span>
      <span class="ta">COMPUTER VISION</span><span>·</span>
      <span>FASTAPI</span><span>·</span>
      <span class="ta">PYTHON</span><span>·</span>
      <span>SCIKIT-LEARN</span><span>·</span>
      <span class="ta">MLOPS</span><span>·</span>
      <span>DOCKER</span><span>·</span>
      <span class="ta">NLP</span><span>·</span>
      <span>PANDAS</span><span>·</span>
      <span class="ta">DEEP LEARNING</span><span>·</span>
      <span>PYTORCH</span><span>·</span>
      <span class="ta">DATA SCIENCE</span><span>·</span>
      <span>MACHINE LEARNING</span><span>·</span>
      <span class="ta">COMPUTER VISION</span><span>·</span>
      <span>FASTAPI</span><span>·</span>
      <span class="ta">PYTHON</span><span>·</span>
      <span>SCIKIT-LEARN</span><span>·</span>
      <span class="ta">MLOPS</span><span>·</span>
      <span>DOCKER</span><span>·</span>
      <span class="ta">NLP</span><span>·</span>
      <span>PANDAS</span><span>·</span>
      <span class="ta">DEEP LEARNING</span><span>·</span>
      <span>PYTORCH</span><span>·</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
    min-height: 94vh;
    display: flex;
    flex-direction: column;
    padding-top: 80px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .hero-inner {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    padding: 3rem 1.5rem 2rem;
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }
  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
      padding: 4rem 2.5rem 3rem;
      gap: 4rem;
    }
  }

  .status-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.5s 0.1s ease forwards;
  }
  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--acid);
    animation: pulse 2s ease infinite;
    flex-shrink: 0;
  }
  .status-text {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.15em;
  }

  .name {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: clamp(3.2rem, 9.5vw, 6.5rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s ease forwards;
  }
  .name-first {
    display: block;
    color: var(--ink);
  }
  .name-last {
    display: block;
    color: var(--acid);
  }
  .name-cursor {
    color: var(--acid);
    animation: pulse 1s step-end infinite;
  }

  .role-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.3s ease forwards;
  }
  .role-tag {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    border: 1px solid rgba(225, 29, 72, 0.12);
    color: var(--acid);
    background: rgba(225, 29, 72, 0.03);
  }
  .role-tag.blue {
    border-color: rgba(37, 99, 235, 0.12);
    color: var(--blue);
    background: rgba(37, 99, 235, 0.03);
  }
  .role-tag.violet {
    border-color: rgba(124, 58, 237, 0.12);
    color: var(--violet);
    background: rgba(124, 58, 237, 0.03);
  }
  .role-sep {
    color: var(--border2);
    font-size: 0.8rem;
  }

  .tagline {
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 2.5rem;
    max-width: 540px;
    opacity: 0;
    animation: fadeUp 0.6s 0.4s ease forwards;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.6s 0.5s ease forwards;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.85rem;
    background: var(--ink);
    color: #ffffff;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-decoration: none;
    border-radius: 8px;
    transition:
      background-color 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
  }
  .cta-primary:hover {
    background: var(--acid);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(225, 29, 72, 0.25);
  }
  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.85rem;
    color: var(--muted);
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-decoration: none;
    border: 1px solid var(--border2);
    border-radius: 8px;
    transition:
      border-color 0.2s,
      color 0.2s,
      background-color 0.2s,
      transform 0.2s;
  }
  .cta-ghost:hover {
    border-color: var(--ink);
    color: var(--ink);
    background-color: rgba(15, 23, 42, 0.02);
    transform: translateY(-1px);
  }
  .cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border2);
    border-radius: 8px;
    color: var(--muted);
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s,
      background-color 0.2s,
      transform 0.2s;
  }
  .cta-icon:hover {
    border-color: var(--ink);
    color: var(--ink);
    background-color: rgba(15, 23, 42, 0.02);
    transform: translateY(-1px);
  }

  /* Scientific Profile Card */
  .hero-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    opacity: 0;
    animation: fadeIn 0.8s 0.6s ease forwards;
    box-shadow:
      0 10px 30px -10px rgba(15, 23, 42, 0.06),
      0 1px 3px rgba(15, 23, 42, 0.02),
      0 30px 60px -15px rgba(15, 23, 42, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .hero-panel:hover {
    transform: translateY(-2px);
    box-shadow:
      0 12px 35px -10px rgba(15, 23, 42, 0.08),
      0 1px 4px rgba(15, 23, 42, 0.03),
      0 35px 70px -15px rgba(15, 23, 42, 0.06);
  }
  .panel-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.4rem;
    border-bottom: 1px solid var(--border);
    background: rgba(15, 23, 42, 0.015);
  }
  .ph-dots {
    display: flex;
    gap: 0.4rem;
  }
  .ph-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .ph-dots span:nth-child(1) {
    background: #ff5f57;
  }
  .ph-dots span:nth-child(2) {
    background: #febc2e;
  }
  .ph-dots span:nth-child(3) {
    background: #28c840;
  }
  .ph-title {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted);
    margin-left: 0.5rem;
    flex: 1;
    letter-spacing: 0.02em;
  }
  .ph-badge {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--acid);
    border: 1px solid rgba(225, 29, 72, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: rgba(225, 29, 72, 0.04);
  }

  .panel-body {
    padding: 1.6rem 1.8rem;
  }
  .pb-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .pb-key {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    width: 90px;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }
  .pb-val {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
  }
  .pb-val.amber {
    color: var(--acid);
  }
  .pb-val.blue {
    color: var(--blue);
  }
  .pb-row-sep {
    flex: 1;
    height: 1px;
    background: var(--border);
    margin: 0.4rem 0;
  }

  .pb-chart-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.95rem;
    margin-top: 0.8rem;
  }
  .pb-chart {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pbc-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .pbc-l {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    width: 62px;
    flex-shrink: 0;
  }
  .pbc-track {
    flex: 1;
    height: 6px;
    background: var(--dim);
    border-radius: 3px;
    overflow: hidden;
  }
  .pbc-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--muted);
    width: 0;
    transition: width 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .amber-fill {
    background: linear-gradient(90deg, var(--acid), #ff4d73);
  }
  .cyan-fill {
    background: linear-gradient(90deg, var(--blue), var(--cyan));
  }
  .violet-fill {
    background: linear-gradient(90deg, var(--violet), #9d66ff);
  }
  .pbc-n {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    width: 24px;
    text-align: right;
  }

  /* Marquee Ribbon */
  .ticker {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 0.95rem 0;
    background: var(--bg2);
    position: relative;
    z-index: 2;
  }
  .ticker-track {
    display: flex;
    white-space: nowrap;
    animation: ticker 32s linear infinite;
  }
  .ticker-track span {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding: 0 1.75rem;
  }
  .ticker-track span.ta {
    color: var(--acid);
  }
</style>

<script>
  // Skill chart trigger
  var panel = document.querySelector(".hero-panel");
  if (panel) {
    var io = new IntersectionObserver(
      function (entries) {
        if (entries[0].isIntersecting) {
          document.querySelectorAll(".pbc-fill").forEach(function (el) {
            el.style.width = el.getAttribute("data-w") + "%";
          });
          io.disconnect();
        }
      },
      { threshold: 0.3 },
    );
    io.observe(panel);
  }

  // Project count counter animation
  var pc = document.getElementById("pCount");
  if (pc) {
    var v = 0;
    var iv = setInterval(function () {
      v++;
      pc.textContent = String(v);
      if (v >= 4) clearInterval(iv);
    }, 180);
  }

  // High-performance interactive particle canvas
  const canvas = document.getElementById("hero-canvas");
  if (canvas) {
    const ctx = canvas.getContext("2d");
    let w = (canvas.width = canvas.offsetWidth);
    let h = (canvas.height = canvas.offsetHeight);

    const particles = [];
    const count = Math.min(45, Math.floor((w * h) / 28000));

    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
        r: Math.random() * 2 + 1,
        color: Math.random() > 0.65 ? "rgba(225, 29, 72, 0.09)" : "rgba(15, 23, 42, 0.04)"
      });
    }

    let mouse = { x: -1000, y: -1000, targetX: -1000, targetY: -1000 };

    window.addEventListener("mousemove", function (e) {
      const rect = canvas.getBoundingClientRect();
      mouse.targetX = e.clientX - rect.left;
      mouse.targetY = e.clientY - rect.top;
    });

    window.addEventListener("mouseleave", function () {
      mouse.targetX = -1000;
      mouse.targetY = -1000;
    });

    let resizeTimeout;
    window.addEventListener("resize", function () {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(function () {
        w = canvas.width = canvas.offsetWidth;
        h = canvas.height = canvas.offsetHeight;
      }, 150);
    });

    function animate() {
      ctx.clearRect(0, 0, w, h);

      // Ease mouse coordinates
      if (mouse.targetX > -1000) {
        if (mouse.x === -1000) {
          mouse.x = mouse.targetX;
          mouse.y = mouse.targetY;
        } else {
          mouse.x += (mouse.targetX - mouse.x) * 0.1;
          mouse.y += (mouse.targetY - mouse.y) * 0.1;
        }
      } else {
        mouse.x = -1000;
        mouse.y = -1000;
      }

      // Update & Draw particles
      particles.forEach(function (p) {
        p.x += p.vx;
        p.y += p.vy;

        // Boundary wrap
        if (p.x < 0) p.x = w;
        if (p.x > w) p.x = 0;
        if (p.y < 0) p.y = h;
        if (p.y > h) p.y = 0;

        // Mouse interaction (repel)
        if (mouse.x > -1000) {
          const dx = p.x - mouse.x;
          const dy = p.y - mouse.y;
          const dist = Math.hypot(dx, dy);
          if (dist < 120) {
            const force = (120 - dist) / 120;
            const angle = Math.atan2(dy, dx);
            p.x += Math.cos(angle) * force * 1.8;
            p.y += Math.sin(angle) * force * 1.8;
          }
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.fill();
      });

      // Connect close particles with lines
      ctx.strokeStyle = "rgba(15, 23, 42, 0.015)";
      ctx.lineWidth = 0.8;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.hypot(dx, dy);
          if (dist < 90) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }

      requestAnimationFrame(animate);
    }

    animate();
  }
</script>
