<section class="hero">

  <div class="scanline" aria-hidden="true"></div>
  <div class="bracket tl" aria-hidden="true"></div>
  <div class="bracket tr" aria-hidden="true"></div>
  <div class="bracket bl" aria-hidden="true"></div>
  <div class="bracket br" aria-hidden="true"></div>
  <div class="hero-ghost" aria-hidden="true">DS</div>

  <div class="hero-inner">
    <div class="hero-left">
      <div class="status-bar">
        <span class="status-dot"></span>
        <span class="font-mono" style="font-size:0.6rem;color:var(--muted);letter-spacing:0.12em">
          SOEUK BONDOL — DATA SCIENTIST — CAMBODIA
        </span>
      </div>

      <h1 class="name">
        <span class="name-first">SOEUK</span>
        <span class="name-last">BONDOL<span class="name-cursor">_</span></span>
      </h1>

      <div class="role-row">
        <span class="role-tag">Data Science</span>
        <span class="role-sep">×</span>
        <span class="role-tag blue">Machine Learning</span>
        <span class="role-sep">×</span>
        <span class="role-tag violet">MLOps</span>
      </div>

      <p class="tagline">
        Turning raw data into decisions.<br/>
        Building models that generalise, pipelines that scale,<br/>
        and systems that actually ship.
      </p>

      <div class="cta-row">
        <a href="#projects" class="cta-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          View Projects
        </a>
        <a href="#contact" class="cta-ghost">Contact me</a>
        <a href="https://github.com/SoeukBondol-ai" target="_blank" rel="noopener" class="cta-icon" title="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="panel-header">
        <div class="ph-dots"><span></span><span></span><span></span></div>
        <span class="ph-title font-mono">sys.profile()</span>
        <span class="ph-badge font-mono">LIVE</span>
      </div>
      <div class="panel-body font-mono">
        <div class="pb-row"><span class="pb-key">role</span><span class="pb-val amber">Data Scientist</span></div>
        <div class="pb-row"><span class="pb-key">location</span><span class="pb-val">Phnom Penh, KH</span></div>
        <div class="pb-row"><span class="pb-key">focus</span><span class="pb-val blue">ML · CV · NLP</span></div>
        <div class="pb-row"><span class="pb-key">lang</span><span class="pb-val amber">Python</span></div>
        <div class="pb-row"><span class="pb-row-sep"></span></div>
        <div class="pb-row"><span class="pb-key">projects</span><span class="pb-val" id="pCount">0</span></div>
        <div class="pb-row"><span class="pb-key">commits</span><span class="pb-val">∞</span></div>
        <div class="pb-row"><span class="pb-key">mouse_use</span><span class="pb-val amber">0ms</span></div>
        <div class="pb-row"><span class="pb-row-sep"></span></div>
        <div class="pb-chart-label">skill_index[]</div>
        <div class="pb-chart">
          <div class="pbc-item">
            <span class="pbc-l">Python</span>
            <div class="pbc-track"><div class="pbc-fill amber-fill" data-w="93"></div></div>
            <span class="pbc-n">93</span>
          </div>
          <div class="pbc-item">
            <span class="pbc-l">ML/DL</span>
            <div class="pbc-track"><div class="pbc-fill cyan-fill" data-w="80"></div></div>
            <span class="pbc-n">80</span>
          </div>
          <div class="pbc-item">
            <span class="pbc-l">SQL</span>
            <div class="pbc-track"><div class="pbc-fill" data-w="76"></div></div>
            <span class="pbc-n">76</span>
          </div>
          <div class="pbc-item">
            <span class="pbc-l">DevOps</span>
            <div class="pbc-track"><div class="pbc-fill violet-fill" data-w="70"></div></div>
            <span class="pbc-n">70</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="ticker">
    <div class="ticker-track">
      <span class="ta">DATA SCIENCE</span><span>·</span>
      <span>MACHINE LEARNING</span><span>·</span>
      <span class="ta">COMPUTER VISION</span><span>·</span>
      <span>FASTAPI</span><span>·</span>
      <span class="ta">PYTHON</span><span>·</span>
      <span>SCIKIT-LEARN</span><span>·</span>
      <span class="ta">MLOPS</span><span>·</span>
      <span>DOCKER</span><span>·</span>
      <span class="ta">NLP</span><span>·</span>
      <span>PANDAS</span><span>·</span>
      <span class="ta">DEEP LEARNING</span><span>·</span>
      <span>PYTORCH</span><span>·</span>
      <span class="ta">DATA SCIENCE</span><span>·</span>
      <span>MACHINE LEARNING</span><span>·</span>
      <span class="ta">COMPUTER VISION</span><span>·</span>
      <span>FASTAPI</span><span>·</span>
      <span class="ta">PYTHON</span><span>·</span>
      <span>SCIKIT-LEARN</span><span>·</span>
      <span class="ta">MLOPS</span><span>·</span>
      <span>DOCKER</span><span>·</span>
      <span class="ta">NLP</span><span>·</span>
      <span>PANDAS</span><span>·</span>
      <span class="ta">DEEP LEARNING</span><span>·</span>
      <span>PYTORCH</span><span>·</span>
    </div>
  </div>
</section>

<style>
.hero { position:relative; z-index:1; min-height:100vh; display:flex; flex-direction:column; padding-top:60px; overflow:hidden; }

.scanline { position:absolute; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(240,180,41,0.2),transparent); animation:scanH 10s linear infinite; pointer-events:none; z-index:0; }

.bracket { position:absolute; width:28px; height:28px; z-index:2; }
.bracket::before,.bracket::after { content:''; position:absolute; background:var(--acid); }
.bracket::before { width:1px; height:100%; }
.bracket::after  { width:100%; height:1px; }
.tl{top:80px;left:20px;} .tl::before{top:0;left:0;} .tl::after{top:0;left:0;}
.tr{top:80px;right:20px;} .tr::before{top:0;right:0;} .tr::after{top:0;right:0;}
.bl{bottom:60px;left:20px;} .bl::before{bottom:0;left:0;} .bl::after{bottom:0;left:0;}
.br{bottom:60px;right:20px;} .br::before{bottom:0;right:0;} .br::after{bottom:0;right:0;}

.hero-ghost { position:absolute; top:50%; left:50%; transform:translate(-50%,-52%); font-family:'Bebas Neue',sans-serif; font-size:clamp(14rem,32vw,30rem); color:transparent; -webkit-text-stroke:1px rgba(255,255,255,0.04); pointer-events:none; user-select:none; white-space:nowrap; letter-spacing:-0.02em; }

.hero-inner { flex:1; display:grid; grid-template-columns:1fr; gap:3rem; align-items:center; padding:3rem 1.5rem 2rem; position:relative; z-index:2; max-width:1200px; width:100%; margin:0 auto; }
@media(min-width:900px){ .hero-inner{ grid-template-columns:1fr 500px; padding:4rem 2.5rem 3rem; gap:4rem; } }

.status-bar { display:flex; align-items:center; gap:0.6rem; margin-bottom:2rem; opacity:0; animation:fadeUp 0.5s 0.1s ease forwards; }
.status-dot { width:7px; height:7px; border-radius:50%; background:var(--acid); animation:pulse 2s ease infinite; flex-shrink:0; }

.name { font-family:'Bebas Neue',sans-serif; font-size:clamp(4.5rem,13vw,11rem); line-height:0.88; letter-spacing:0.01em; margin-bottom:1.5rem; opacity:0; animation:fadeUp 0.6s 0.2s ease forwards; }
.name-first { display:block; color:var(--ink); }
.name-last  { display:block; color:transparent; -webkit-text-stroke:2px var(--acid); }
@media(max-width:480px){ .name-last{ -webkit-text-stroke:1.5px var(--acid); } }
.name-cursor { color:var(--acid); -webkit-text-stroke:0; animation:pulse 1s step-end infinite; }

.role-row { display:flex; flex-wrap:wrap; align-items:center; gap:0.5rem; margin-bottom:1.75rem; opacity:0; animation:fadeUp 0.6s 0.3s ease forwards; }
.role-tag { font-family:'JetBrains Mono',monospace; font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.28rem 0.7rem; border-radius:3px; border:1px solid rgba(240,180,41,0.3); color:var(--acid); background:rgba(240,180,41,0.08); }
.role-tag.blue   { border-color:rgba(77,157,224,0.3); color:var(--blue);   background:rgba(77,157,224,0.08); }
.role-tag.violet { border-color:rgba(167,139,250,0.3); color:var(--violet); background:rgba(167,139,250,0.08); }
.role-sep { color:var(--muted); font-size:0.7rem; }

.tagline { font-size:clamp(0.78rem,1.4vw,0.92rem); line-height:1.85; color:var(--muted); margin-bottom:2.5rem; max-width:500px; opacity:0; animation:fadeUp 0.6s 0.4s ease forwards; }

.cta-row { display:flex; flex-wrap:wrap; gap:0.75rem; align-items:center; opacity:0; animation:fadeUp 0.6s 0.5s ease forwards; }
.cta-primary { display:inline-flex; align-items:center; gap:0.5rem; padding:0.7rem 1.4rem; background:var(--acid); color:#000; font-family:'JetBrains Mono',monospace; font-size:0.67rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border-radius:5px; transition:opacity 0.2s,transform 0.2s; }
.cta-primary:hover { opacity:0.85; transform:translateY(-1px); }
.cta-ghost { display:inline-flex; align-items:center; gap:0.5rem; padding:0.7rem 1.4rem; color:var(--muted); font-family:'JetBrains Mono',monospace; font-size:0.67rem; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border:1px solid var(--border2); border-radius:5px; transition:border-color 0.2s,color 0.2s; }
.cta-ghost:hover { border-color:var(--acid); color:var(--acid); }
.cta-icon { display:inline-flex; align-items:center; justify-content:center; width:40px; height:40px; border:1px solid var(--border2); border-radius:5px; color:var(--muted); text-decoration:none; transition:border-color 0.2s,color 0.2s; }
.cta-icon:hover { border-color:var(--acid); color:var(--acid); }

/* Panel */
.hero-panel { background:var(--surface); border:1px solid var(--border2); border-radius:12px; overflow:hidden; opacity:0; animation:fadeIn 0.8s 0.7s ease forwards; box-shadow:0 0 0 1px rgba(240,180,41,0.06), 0 24px 60px rgba(0,0,0,0.4); }
.panel-header { display:flex; align-items:center; gap:0.6rem; padding:0.85rem 1.25rem; border-bottom:1px solid var(--border); background:rgba(255,255,255,0.025); }
.ph-dots { display:flex; gap:0.4rem; }
.ph-dots span { width:11px; height:11px; border-radius:50%; }
.ph-dots span:nth-child(1){background:#ff5f57;} .ph-dots span:nth-child(2){background:#febc2e;} .ph-dots span:nth-child(3){background:#28c840;}
.ph-title { font-size:0.75rem; color:var(--muted); margin-left:0.5rem; flex:1; }
.ph-badge { font-size:0.62rem; letter-spacing:0.12em; color:var(--acid); border:1px solid rgba(240,180,41,0.35); padding:0.15rem 0.45rem; border-radius:2px; background:rgba(240,180,41,0.08); }

.panel-body { padding:1.5rem 1.75rem 1.75rem; }
.pb-row { display:flex; align-items:center; gap:0.75rem; margin-bottom:0.7rem; }
.pb-key  { font-size:0.75rem; color:var(--muted); width:90px; flex-shrink:0; letter-spacing:0.04em; }
.pb-val  { font-size:0.78rem; color:var(--ink); }
.pb-val.amber { color:var(--acid); }
.pb-val.blue  { color:var(--blue); }
.pb-row-sep { flex:1; height:1px; background:var(--border); margin:0.35rem 0; }

.pb-chart-label { font-size:0.68rem; color:var(--muted); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:0.75rem; margin-top:0.4rem; }
.pb-chart { display:flex; flex-direction:column; gap:0.65rem; }
.pbc-item { display:flex; align-items:center; gap:0.6rem; }
.pbc-l { font-size:0.72rem; color:var(--muted); width:62px; flex-shrink:0; }
.pbc-track { flex:1; height:6px; background:var(--border); border-radius:3px; overflow:hidden; }
.pbc-fill { height:100%; border-radius:3px; background:var(--muted); width:0; transition:width 1.4s cubic-bezier(0.16,1,0.3,1); }
.amber-fill  { background:var(--acid); }
.cyan-fill   { background:var(--cyan); }
.violet-fill { background:var(--violet); }
.pbc-n { font-size:0.66rem; color:var(--muted); width:24px; text-align:right; }

.ticker { border-top:1px solid var(--border); overflow:hidden; padding:0.85rem 0; background:var(--bg2); position:relative; z-index:2; }
.ticker-track { display:flex; white-space:nowrap; animation:ticker 28s linear infinite; }
.ticker-track span { font-family:'Bebas Neue',sans-serif; font-size:0.95rem; letter-spacing:0.12em; color:var(--muted); padding:0 1.5rem; }
.ticker-track span.ta { color:var(--acid); }
</style>

<script>
var pc = document.getElementById('pCount');
if (pc) {
  var v = 0;
  var iv = setInterval(function() {
    v++; pc.textContent = String(v);
    if (v >= 4) clearInterval(iv);
  }, 180);
}
var panel = document.querySelector('.hero-panel');
if (panel) {
  var io = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) {
      document.querySelectorAll('.pbc-fill').forEach(function(el) {
        el.style.width = el.getAttribute('data-w') + '%';
      });
      io.disconnect();
    }
  }, { threshold: 0.3 });
  io.observe(panel);
}
</script>