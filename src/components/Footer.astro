---

---

<footer>
  <div class="fi">
    <div class="fl">
      <span class="fl-logo"
        >SB<span class="br">.</span></span
      >
      <span class="fl-role">Data Scientist</span>
    </div>
    <div class="fc">
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
      <a href="#stack">Stack</a>
      <a href="#contact">Contact</a>
      <a href="https://github.com/SoeukBondol-ai" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
    <span class="fr font-mono">© {new Date().getFullYear()} Soeuk Bondol</span>
  </div>
</footer>

<style>
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    background: var(--bg);
  }
  @media (min-width: 640px) {
    footer {
      padding: 2.2rem 2.5rem;
    }
  }
  .fi {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
  }
  .fl {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .fl-logo {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .br {
    color: var(--acid);
  }
  .fl-role {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.05em;
    font-family: "Plus Jakarta Sans", sans-serif;
    text-transform: uppercase;
  }
  .fc {
    display: flex;
    gap: 1.8rem;
    flex-wrap: wrap;
  }
  .fc a {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .fc a:hover {
    color: var(--acid);
  }
  .fr {
    font-size: 0.65rem;
    color: var(--muted);
    opacity: 0.65;
    font-weight: 500;
  }
</style>
