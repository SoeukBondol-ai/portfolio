---
// Using simpleicons.org API — fetched at build time as colored SVGs
// Color hex WITHOUT # — picked for max visibility on navy background
const stack = [
  { name: 'Python',       icon: 'python',       color: '4b9cd3', cat: 'Data & ML' },
  { name: 'PyTorch',      icon: 'pytorch',       color: 'ee4c2c', cat: 'Data & ML' },
  { name: 'Scikit-learn', icon: 'scikitlearn',   color: 'f7931e', cat: 'Data & ML' },
  { name: 'Pandas',       icon: 'pandas',        color: '5b9bd5', cat: 'Data & ML' },
  { name: 'NumPy',        icon: 'numpy',         color: '4dabcf', cat: 'Data & ML' },
  { name: 'OpenCV',       icon: 'opencv',        color: '9b72cf', cat: 'Data & ML' },
  { name: 'Jupyter',      icon: 'jupyter',       color: 'f37626', cat: 'Data & ML' },
  { name: 'FastAPI',      icon: 'fastapi',       color: '00d4aa', cat: 'Backend'   },
  { name: 'PostgreSQL',   icon: 'postgresql',    color: '6ea7d8', cat: 'Backend'   },
  { name: 'SQLAlchemy',   icon: 'sqlalchemy',    color: 'e83524', cat: 'Backend'   },
  { name: 'Docker',       icon: 'docker',        color: '2496ed', cat: 'DevOps'    },
  { name: 'GitHub',       icon: 'github',        color: 'c9d1d9', cat: 'DevOps'    },
  { name: 'Linux',        icon: 'linux',         color: 'fcc624', cat: 'DevOps'    },
  { name: 'Git',          icon: 'git',           color: 'f05032', cat: 'DevOps'    },
  { name: 'Neovim',       icon: 'neovim',        color: '57a143', cat: 'Tools'     },
  { name: 'Astro',        icon: 'astro',         color: 'ff5d01', cat: 'Tools'     },
  { name: 'HuggingFace',  icon: null,            color: 'ffd21e', cat: 'Tools', emoji: '🤗' },
  { name: 'uv',           icon: null,            color: 'de5fe9', cat: 'Tools', text: 'uv'  },
];

const cats = ['Data & ML', 'Backend', 'DevOps', 'Tools'];
---

<section class="stack" id="stack">
  <div class="stack-inner">
    <div class="sec-eye reveal">
      <span class="sec-eye-num">03</span>
      <div class="sec-eye-line"></div>
      <span class="sec-eye-txt">Stack</span>
    </div>

    <div class="sh reveal">
      <h2 class="sh-title">THE<br/><em>TOOLKIT.</em></h2>
      <p class="sh-sub">Every tool chosen with intent. Zero bloat.</p>
    </div>

    <div class="cat-tabs reveal">
      <button class="ctab active" data-cat="all">All</button>
      {cats.map(c => <button class="ctab" data-cat={c}>{c}</button>)}
    </div>

    <div class="logo-grid reveal">
      {stack.map(tool => (
        <div class="logo-card" data-cat={tool.cat} title={tool.name}>
          <div class="lc-icon">
            {tool.icon ? (
              <img
                src={`https://cdn.simpleicons.org/${tool.icon}/${tool.color}`}
                alt={tool.name}
                width="36" height="36"
                loading="lazy"
                decoding="async"
              />
            ) : tool.emoji ? (
              <span class="lc-emoji">{tool.emoji}</span>
            ) : (
              <span class="lc-text" style={`color:#${tool.color}`}>{tool.text}</span>
            )}
          </div>
          <span class="lc-name">{tool.name}</span>
        </div>
      ))}
    </div>

    <div class="proficiency reveal">
      <div class="prof-header font-mono">
        <span>skill_matrix.json</span>
        <span class="prof-badge">CURRENT</span>
      </div>
      <div class="prof-grid">
        {[
          { name: 'Python',           level: 93, cat: 'Data & ML', color: 'var(--acid)' },
          { name: 'Data Analysis',    level: 88, cat: 'Data & ML', color: 'var(--acid)' },
          { name: 'Machine Learning', level: 82, cat: 'ML',        color: 'var(--cyan)'  },
          { name: 'FastAPI',          level: 80, cat: 'Backend',   color: 'var(--cyan)'  },
          { name: 'Linux / Bash',     level: 85, cat: 'DevOps',    color: 'var(--violet)'},
          { name: 'SQL',              level: 76, cat: 'Data',      color: 'var(--acid)' },
          { name: 'Docker',           level: 72, cat: 'DevOps',    color: 'var(--violet)'},
          { name: 'Deep Learning',    level: 70, cat: 'ML',        color: 'var(--cyan)'  },
        ].map((s, i) => (
          <div class="prof-row">
            <div class="pr-meta">
              <span class="pr-name font-mono">{s.name}</span>
              <span class="pr-cat font-mono">{s.cat}</span>
            </div>
            <div class="pr-track">
              <div class="pr-fill" data-w={s.level}
                style={`transition-delay:${i*0.07}s;--bc:${s.color}`}></div>
            </div>
            <span class="pr-num font-mono">{s.level}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.stack {
  position:relative; z-index:1;
  padding:5rem 1.5rem;
  border-top:1px solid var(--border);
}
@media(min-width:640px){ .stack{ padding:7rem 2.5rem; } }
.stack-inner { max-width:1200px; margin:0 auto; }

.sh { margin-bottom:2.5rem; }
.sh-title {
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3rem,8vw,6.5rem); line-height:0.9; margin-bottom:0.75rem;
}
.sh-title em { color:var(--acid); font-style:normal; }
.sh-sub { font-size:0.82rem; color:var(--muted); }

/* TABS */
.cat-tabs { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2rem; }
.ctab {
  font-family:'JetBrains Mono',monospace; font-size:0.62rem;
  letter-spacing:0.08em; text-transform:uppercase;
  padding:0.35rem 0.9rem; border-radius:5px; cursor:pointer;
  border:1px solid var(--border2); background:var(--surface); color:var(--muted);
  transition:all 0.15s;
}
.ctab:hover { border-color:var(--acid); color:var(--acid); background:var(--lift); }
.ctab.active {
  border-color:var(--acid); color:#000;
  background:var(--acid); font-weight:600;
}

/* LOGO GRID */
.logo-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(105px, 1fr));
  gap:1px; background:var(--border);
  border:1px solid var(--border); border-radius:12px; overflow:hidden;
  margin-bottom:2rem;
}

.logo-card {
  background:var(--surface);
  padding:1.75rem 0.75rem 1.25rem;
  display:flex; flex-direction:column; align-items:center; gap:0.7rem;
  transition:background 0.2s; cursor:default; position:relative; overflow:hidden;
}
.logo-card::before {
  content:''; position:absolute; inset:0;
  background:radial-gradient(circle at 50% 0%, rgba(240,180,41,0.08), transparent 65%);
  opacity:0; transition:opacity 0.25s;
}
.logo-card:hover { background:var(--lift); }
.logo-card:hover::before { opacity:1; }
.logo-card.hidden { display:none; }

.lc-icon {
  width:44px; height:44px;
  display:flex; align-items:center; justify-content:center;
}

/* Icons rendered with correct brand color from simpleicons CDN */
.lc-icon img {
  width:36px; height:36px; object-fit:contain;
  transition:transform 0.25s;
  /* no filter — color is already baked in via URL */
}
.logo-card:hover .lc-icon img { transform:scale(1.18) translateY(-3px); }

.lc-emoji {
  font-size:2.1rem; line-height:1;
  transition:transform 0.25s; display:block;
}
.logo-card:hover .lc-emoji { transform:scale(1.15) translateY(-3px); }

.lc-text {
  font-family:'JetBrains Mono',monospace;
  font-size:1.1rem; font-weight:700; letter-spacing:0.05em;
  transition:transform 0.25s;
}
.logo-card:hover .lc-text { transform:scale(1.1) translateY(-2px); }

.lc-name {
  font-family:'JetBrains Mono',monospace;
  font-size:0.58rem; color:var(--muted); text-align:center;
  letter-spacing:0.02em; line-height:1.3; transition:color 0.2s;
}
.logo-card:hover .lc-name { color:var(--ink); }

/* PROFICIENCY */
.proficiency {
  background:var(--surface); border:1px solid var(--border);
  border-radius:12px; overflow:hidden;
}
.prof-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:0.85rem 1.4rem; border-bottom:1px solid var(--border);
  font-size:0.62rem; color:var(--muted); background:rgba(255,255,255,0.02);
}
.prof-badge {
  font-size:0.52rem; letter-spacing:0.12em; color:var(--acid);
  border:1px solid rgba(240,180,41,0.35); padding:0.12rem 0.4rem; border-radius:3px;
  background:rgba(240,180,41,0.08);
}
.prof-grid { padding:1.5rem; display:flex; flex-direction:column; gap:0.9rem; }
.prof-row { display:grid; grid-template-columns:190px 1fr 34px; align-items:center; gap:0.85rem; }
@media(max-width:560px){ .prof-row{ grid-template-columns:115px 1fr 28px; } }
.pr-meta { display:flex; flex-direction:column; gap:0.18rem; }
.pr-name { font-size:0.68rem; color:var(--ink); }
.pr-cat  { font-size:0.53rem; color:var(--muted); }
.pr-track {
  height:6px; background:var(--border); border-radius:3px; overflow:hidden;
}
.pr-fill {
  height:100%; border-radius:3px; width:0;
  background:var(--bc, var(--acid));
  transition:width 1.4s cubic-bezier(0.16,1,0.3,1);
}
.pr-num { font-size:0.6rem; color:var(--muted); text-align:right; }

.reveal { opacity:0; transform:translateY(24px); transition:opacity 0.7s ease, transform 0.7s ease; }
.reveal.on { opacity:1; transform:none; }
</style>

<script>
var tabs  = document.querySelectorAll('.ctab');
var cards = document.querySelectorAll('.logo-card');
tabs.forEach(function(tab) {
  tab.addEventListener('click', function() {
    tabs.forEach(function(t) { t.classList.remove('active'); });
    tab.classList.add('active');
    var cat = tab.getAttribute('data-cat');
    cards.forEach(function(card) {
      if (cat === 'all' || card.getAttribute('data-cat') === cat) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  });
});

var prof = document.querySelector('.proficiency');
if (prof) {
  var io = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) {
      document.querySelectorAll('.pr-fill').forEach(function(el) {
        el.style.width = el.getAttribute('data-w') + '%';
      });
      io.disconnect();
    }
  }, { threshold: 0.2 });
  io.observe(prof);
}
var ro = new IntersectionObserver(function(es) {
  es.forEach(function(e) {
    if (e.isIntersecting) { e.target.classList.add('on'); ro.unobserve(e.target); }
  });
}, { threshold: 0.06 });
document.querySelectorAll('.reveal').forEach(function(el) { ro.observe(el); });
</script>