---
const categories = [
  {
    label: 'Data & ML',
    color: 'acid',
    tools: ['Python','Pandas','NumPy','Scikit-learn','PyTorch','TensorFlow','Matplotlib','Seaborn','Jupyter'],
  },
  {
    label: 'Backend & APIs',
    color: 'cyan',
    tools: ['FastAPI','PostgreSQL','SQLAlchemy','REST','JWT','Pydantic','Uvicorn'],
  },
  {
    label: 'DevOps & Tools',
    color: 'violet',
    tools: ['Docker','Git','Linux','Bash','Neovim','tmux','GitHub Actions','SSH'],
  },
  {
    label: 'Data Engineering',
    color: 'amber',
    tools: ['SQL','ETL','Airflow','dbt','CSV/JSON','Data Cleaning','EDA'],
  },
];
const colorMap: Record<string,string> = {
  acid:'#c8ff57', cyan:'#38d9f5', violet:'#8b5cf6', amber:'#f59e0b',
};
---

<section class="stack" id="stack">
  <div class="stack-inner">
    <div class="sec-eye reveal">
      <span class="sec-eye-num">03</span>
      <div class="sec-eye-line"></div>
      <span class="sec-eye-txt">Stack</span>
    </div>

    <div class="sh reveal">
      <h2 class="sh-title">THE<br/><em>TOOLKIT.</em></h2>
      <p class="sh-sub">Every tool chosen with intent. Zero bloat.</p>
    </div>

    <div class="cats">
      {categories.map((cat, i) => (
        <div class="cat reveal" style={`--cc:${colorMap[cat.color]};transition-delay:${i*0.1}s`}>
          <div class="cat-header">
            <span class="cat-indicator"></span>
            <span class="cat-label font-mono">{cat.label}</span>
          </div>
          <div class="cat-tools">
            {cat.tools.map(t => <span class="tool">{t}</span>)}
          </div>
        </div>
      ))}
    </div>

    <!-- Proficiency visual -->
    <div class="proficiency reveal">
      <div class="prof-header font-mono">
        <span>skill_matrix.json</span>
        <span class="prof-badge">CURRENT</span>
      </div>
      <div class="prof-grid">
        {[
          { name: 'Python',          level: 93, cat: 'Data & ML'   },
          { name: 'Data Analysis',   level: 88, cat: 'Data & ML'   },
          { name: 'Machine Learning',level: 82, cat: 'ML'          },
          { name: 'FastAPI',         level: 80, cat: 'Backend'     },
          { name: 'SQL',             level: 76, cat: 'Data'        },
          { name: 'Docker',          level: 72, cat: 'DevOps'      },
          { name: 'Deep Learning',   level: 70, cat: 'ML'          },
          { name: 'Linux / Bash',    level: 85, cat: 'DevOps'      },
        ].map((s,i) => (
          <div class="prof-row">
            <div class="pr-meta">
              <span class="pr-name font-mono">{s.name}</span>
              <span class="pr-cat font-mono">{s.cat}</span>
            </div>
            <div class="pr-track">
              <div class="pr-fill" data-w={s.level} style={`transition-delay:${i*0.07}s`}></div>
            </div>
            <span class="pr-num font-mono">{s.level}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.stack { position:relative; z-index:1; padding:5rem 1.5rem; border-top:1px solid var(--border); }
@media(min-width:640px){ .stack{ padding:7rem 2.5rem; } }
.stack-inner { max-width:1200px; margin:0 auto; }

.sh { margin-bottom:3.5rem; }
.sh-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(3rem,8vw,6.5rem); line-height:0.9; margin-bottom:0.75rem; }
.sh-title em { color:var(--acid); font-style:normal; }
.sh-sub { font-size:0.8rem; color:var(--muted); }

.cats { display:grid; grid-template-columns:1fr; gap:1px; background:var(--border); border:1px solid var(--border); border-radius:10px; overflow:hidden; margin-bottom:2rem; }
@media(min-width:640px){ .cats{ grid-template-columns:1fr 1fr; } }
@media(min-width:900px){ .cats{ grid-template-columns:repeat(4,1fr); } }

.cat { background:var(--bg); padding:1.75rem 1.5rem; transition:background 0.2s; }
.cat:hover { background:var(--surface); }
.cat-header { display:flex; align-items:center; gap:0.6rem; margin-bottom:1.25rem; }
.cat-indicator { width:8px; height:8px; border-radius:50%; background:var(--cc); flex-shrink:0; }
.cat-label { font-size:0.6rem; color:var(--cc); letter-spacing:0.12em; text-transform:uppercase; }
.cat-tools { display:flex; flex-wrap:wrap; gap:0.35rem; }
.tool {
  font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.04em;
  padding:0.2rem 0.55rem; border:1px solid var(--border); border-radius:3px;
  color:var(--muted); background:var(--surface); transition:border-color 0.2s, color 0.2s;
}
.cat:hover .tool { border-color:color-mix(in srgb,var(--cc) 20%,var(--border)); }
.cat:hover .tool:hover { border-color:var(--cc); color:var(--cc); }

/* proficiency */
.proficiency {
  background:var(--surface); border:1px solid var(--border2); border-radius:10px; overflow:hidden;
}
.prof-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:0.75rem 1.25rem; border-bottom:1px solid var(--border);
  font-size:0.6rem; color:var(--muted);
  background:rgba(255,255,255,0.02);
}
.prof-badge {
  font-size:0.5rem; letter-spacing:0.12em; color:var(--acid);
  border:1px solid rgba(200,255,87,0.3); padding:0.1rem 0.35rem; border-radius:2px;
}
.prof-grid { padding:1.25rem; display:flex; flex-direction:column; gap:0.85rem; }
.prof-row { display:grid; grid-template-columns:200px 1fr 32px; align-items:center; gap:0.75rem; }
@media(max-width:560px){ .prof-row{ grid-template-columns:120px 1fr 28px; } }
.pr-meta { display:flex; flex-direction:column; gap:0.15rem; }
.pr-name { font-size:0.65rem; color:var(--ink); }
.pr-cat  { font-size:0.52rem; color:var(--muted); }
.pr-track { height:4px; background:var(--border); border-radius:2px; overflow:hidden; }
.pr-fill {
  height:100%; background:linear-gradient(90deg,var(--acid),var(--cyan));
  border-radius:2px; width:0; transition:width 1.4s cubic-bezier(0.16,1,0.3,1);
}
.pr-num { font-size:0.58rem; color:var(--muted); text-align:right; }
</style>

<script>
const prof = document.querySelector('.proficiency');
if (prof) {
  const io = new IntersectionObserver(([e]) => {
    if (e.isIntersecting) {
      document.querySelectorAll('.pr-fill').forEach((el: Element) => {
        const b = el as HTMLElement;
        b.style.width = (b.dataset.w || '0') + '%';
      });
      io.disconnect();
    }
  }, { threshold: 0.2 });
  io.observe(prof);
}
</script>
