---

<section class="contact" id="contact">
  <div class="contact-inner">
    <div class="sec-eye reveal">
      <span class="sec-eye-num">04</span>
      <div class="sec-eye-line"></div>
      <span class="sec-eye-txt">Contact</span>
    </div>

    <div class="contact-layout">
      <div class="cl reveal">
        <h2 class="ct-big">
          LET'S<br />
          <span class="stroke">BUILD</span><br />
          <em>SOMETHING.</em>
        </h2>
        <p class="ct-desc">
          Open to data science roles, ML consulting, freelance projects, and
          interesting collaborations. Based in Cambodia — available remotely
          worldwide. I reply to everything.
        </p>
        <a href="mailto:soeukbondolcc@gmail.com" class="email-cta">
          <span class="ec-label font-mono">Send me an email</span>
          <span class="ec-addr">soeukbondolcc@gmail.com</span>
          <span class="ec-arrow">↗</span>
        </a>
      </div>

      <div class="cr reveal" style="transition-delay:0.15s">
        <div class="socials">
          <a
            href="https://github.com/SoeukBondol-ai"
            target="_blank"
            rel="noopener"
            class="soc"
          >
            <div class="soc-left">
              <div class="soc-ico">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                  ></path></svg
                >
              </div>
              <div>
                <div class="soc-name">GitHub</div>
                <div class="soc-sub font-mono">@SoeukBondol-ai</div>
              </div>
            </div>
            <span class="soc-arr">↗</span>
          </a>

          <a href="mailto:soeukbondolcc@gmail.com" class="soc">
            <div class="soc-left">
              <div class="soc-ico">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
                >
              </div>
              <div>
                <div class="soc-name">Gmail</div>
                <div class="soc-sub font-mono">soeukbondolcc@gmail.com</div>
              </div>
            </div>
            <span class="soc-arr">↗</span>
          </a>
        </div>

        <!-- availability card -->
        <div class="avail font-mono">
          <div class="avail-top">
            <span class="avail-dot"></span>
            <span class="avail-status">Available for opportunities</span>
          </div>
          <div class="avail-details">
            <div class="ad-row">
              <span class="adk">Type</span><span class="adv"
                >Full-time · Freelance · Contract</span
              >
            </div>
            <div class="ad-row">
              <span class="adk">Mode</span><span class="adv"
                >Remote worldwide</span
              >
            </div>
            <div class="ad-row">
              <span class="adk">TZ</span><span class="adv">ICT (UTC+7)</span>
            </div>
            <div class="ad-row">
              <span class="adk">Response</span><span class="adv acid"
                >&lt; 24h</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    z-index: 1;
    padding: 4rem 1.25rem 4.5rem;
    border-top: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .contact {
      padding: 5.25rem 2rem 5.5rem;
    }
  }
  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
    }
  }

  .ct-big {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(3.5rem, 9vw, 7.5rem);
    line-height: 0.88;
    margin-bottom: 1.75rem;
  }
  .stroke {
    color: transparent;
    -webkit-text-stroke: 2px rgba(232, 234, 242, 0.25);
  }
  .ct-big em {
    color: var(--acid);
    font-style: normal;
  }
  .ct-desc {
    font-size: 0.83rem;
    color: var(--muted);
    line-height: 1.85;
    margin-bottom: 2.5rem;
    max-width: 420px;
  }

  .email-cta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(200, 255, 87, 0.25);
    border-radius: 8px;
    background: rgba(200, 255, 87, 0.04);
    text-decoration: none;
    transition:
      background 0.2s,
      border-color 0.2s;
    position: relative;
  }
  .email-cta:hover {
    background: rgba(200, 255, 87, 0.08);
    border-color: rgba(200, 255, 87, 0.5);
  }
  .ec-label {
    font-size: 0.56rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .ec-addr {
    font-size: 0.9rem;
    color: var(--acid);
    font-family: "JetBrains Mono", monospace;
  }
  .ec-arrow {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    color: var(--acid);
    font-size: 1.1rem;
  }

  .socials {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .soc {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink);
    transition: all 0.2s;
  }
  .soc:hover {
    border-color: rgba(200, 255, 87, 0.25);
    background: var(--lift);
  }
  .soc-left {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .soc-ico {
    width: 36px;
    height: 36px;
    background: var(--lift);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition: color 0.2s;
  }
  .soc:hover .soc-ico {
    color: var(--acid);
  }
  .soc-name {
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 0.18rem;
  }
  .soc-sub {
    font-size: 0.58rem;
    color: var(--muted);
  }
  .soc-arr {
    color: var(--muted);
    transition:
      color 0.2s,
      transform 0.2s;
  }
  .soc:hover .soc-arr {
    color: var(--acid);
    transform: translate(2px, -2px);
  }

  .avail {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 8px;
    overflow: hidden;
  }
  .avail-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(200, 255, 87, 0.04);
  }
  .avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--acid);
    animation: pulse 2s ease infinite;
  }
  .avail-status {
    font-size: 0.6rem;
    color: var(--acid);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .avail-details {
    padding: 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ad-row {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }
  .adk {
    font-size: 0.56rem;
    color: var(--muted);
    width: 64px;
    flex-shrink: 0;
    letter-spacing: 0.06em;
  }
  .adv {
    font-size: 0.62rem;
    color: var(--ink);
  }
  .adv.acid {
    color: var(--acid);
  }
</style>
