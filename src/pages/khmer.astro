---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const API_BASE = "https://mondolreal-khmer-digit-api.hf.space";
const BASE_URL = import.meta.env.BASE_URL;
---

<Base title="Khmer Digit Recognition — Soeuk Bondol">
  <Nav />

  <main class="demo-page">
    <!-- HEADER -->
    <div class="demo-header">
      <a href={`${BASE_URL}#projects`} class="back-link font-mono"
        >← Back to projects</a
      >
      <div class="dh-inner">
        <div class="dh-eye">
          <span class="dh-num font-mono">001</span>
          <div class="dh-line"></div>
          <span class="dh-label font-mono">Live Demo</span>
        </div>
        <h1 class="dh-title">KHMER DIGIT<br /><em>RECOGNITION</em></h1>
        <p class="dh-desc">
          Draw a Khmer numeral on the canvas. Choose LeNet or ResNet — the model
          running on Hugging Face Spaces predicts in real time.
        </p>
        <div class="dh-badges">
          <span class="dbadge acid font-mono">LeNet CNN</span>
          <span class="dbadge cyan font-mono">ResNet-18</span>
          <span class="dbadge violet font-mono">FastAPI</span>
          <span class="dbadge font-mono">HuggingFace</span>
        </div>
      </div>
    </div>

    <!-- REFERENCE: Khmer digits -->
    <div class="ref-strip">
      <span class="ref-label font-mono">Khmer digits reference:</span>
      <div class="ref-digits">
        {
          ["០", "១", "២", "៣", "៤", "៥", "៦", "៧", "៨", "៩"].map((d, i) => (
            <span class="ref-d">
              <span class="ref-kh">{d}</span>
              <span class="ref-n font-mono">{i}</span>
            </span>
          ))
        }
      </div>
    </div>

    <!-- MAIN DEMO GRID -->
    <div class="demo-grid">
      <!-- LEFT: Canvas -->
      <div class="canvas-panel">
        <div class="cp-header">
          <div class="cp-dots">
            <span class="r"></span><span class="y"></span><span class="g"
            ></span>
          </div>
          <span class="cp-title font-mono">canvas.draw()</span>
          <div class="model-toggle">
            <button class="mtb active" data-model="lenet" id="btnLenet"
              >LeNet</button
            >
            <button class="mtb" data-model="resnet" id="btnResnet"
              >ResNet</button
            >
          </div>
        </div>

        <div class="canvas-wrap">
          <canvas id="drawCanvas" width="500" height="500"></canvas>
          <div class="canvas-hint" id="canvasHint">Draw a Khmer digit here</div>
        </div>

        <div class="canvas-footer">
          <button class="cf-clear" id="clearBtn">
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"></path></svg
            >
            Clear
          </button>
          <div class="cf-status font-mono" id="statusEl">
            <span class="status-dot idle"></span>
            <span id="statusText">Ready — draw to predict</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Results -->
      <div class="result-panel">
        <!-- Big prediction -->
        <div class="pred-card">
          <div class="pc-label font-mono">prediction</div>
          <div class="pc-digit" id="predDigit">–</div>
          <div class="pc-khmer" id="predKhmer">?</div>
          <div class="pc-conf font-mono" id="predConf">— % confident</div>
          <div class="pc-model font-mono" id="predModel">model: —</div>
        </div>

        <!-- Probability bars -->
        <div class="prob-panel">
          <div class="pp-header font-mono">
            <span>probability_dist[]</span>
            <span class="pp-badge" id="ppBadge">waiting</span>
          </div>
          <div class="pp-bars" id="probBars">
            {
              ["០", "១", "២", "៣", "៤", "៥", "៦", "៧", "៨", "៩"].map((d, i) => (
                <div class="pb-row" data-idx={i}>
                  <span class="pb-kh">{d}</span>
                  <span class="pb-num font-mono">{i}</span>
                  <div class="pb-track">
                    <div class="pb-fill" style="width:0%" data-idx={i} />
                  </div>
                  <span class="pb-pct font-mono" data-idx={i}>
                    —
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- API INFO -->
    <div class="api-info reveal">
      <div class="ai-header font-mono">
        <span class="ai-dot"></span>
        API endpoint — live on Hugging Face Spaces
      </div>
      <div class="ai-url font-mono">
        POST https://mondolreal-khmer-digit-api.hf.space/predict/<span
          style="opacity:0.6">[lenet|resnet]</span
        >
      </div>
      <div class="ai-links">
        <a
          href="https://huggingface.co/spaces/mondolreal/khmer-digit-api"
          target="_blank"
          rel="noopener"
          class="ai-link">HuggingFace Space ↗</a
        >
        <a
          href="https://github.com/SoeukBondol-ai/khmer-number-recognition"
          target="_blank"
          rel="noopener"
          class="ai-link">GitHub Repo ↗</a
        >
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  /* PAGE */
  .demo-page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding-top: 72px;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    padding-bottom: 3.5rem;
  }
  @media (min-width: 640px) {
    .demo-page {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    display: block;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--acid);
  }

  /* HEADER */
  .demo-header {
    margin-bottom: 2rem;
  }
  .dh-eye {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .dh-num {
    font-size: 0.58rem;
    color: var(--acid);
    letter-spacing: 0.12em;
  }
  .dh-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 48px;
  }
  .dh-label {
    font-size: 0.58rem;
    color: var(--muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .dh-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    margin-bottom: 1.25rem;
  }
  .dh-title em {
    color: var(--acid);
    font-style: normal;
  }
  .dh-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 560px;
    margin-bottom: 1.5rem;
  }
  .dh-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .dbadge {
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.22rem 0.6rem;
    border-radius: 3px;
    border: 1px solid var(--border2);
    color: var(--muted);
    background: var(--surface);
  }
  .dbadge.acid {
    border-color: rgba(200, 255, 87, 0.3);
    color: var(--acid);
    background: rgba(200, 255, 87, 0.06);
  }
  .dbadge.cyan {
    border-color: rgba(56, 217, 245, 0.3);
    color: var(--cyan);
    background: rgba(56, 217, 245, 0.06);
  }
  .dbadge.violet {
    border-color: rgba(139, 92, 246, 0.3);
    color: var(--violet);
    background: rgba(139, 92, 246, 0.06);
  }

  /* REFERENCE STRIP */
  .ref-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .ref-label {
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .ref-digits {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .ref-d {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    transition: border-color 0.2s;
  }
  .ref-d:hover {
    border-color: var(--acid);
  }
  .ref-kh {
    font-size: 1.3rem;
    line-height: 1;
    color: var(--ink);
    font-family: "Kantumruy Pro", serif;
  }
  .ref-n {
    font-size: 0.5rem;
    color: var(--muted);
  }

  /* MAIN GRID */
  .demo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 860px) {
    .demo-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  /* CANVAS PANEL */
  .canvas-panel {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 10px;
    overflow: hidden;
  }
  .cp-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
  }
  .cp-dots {
    display: flex;
    gap: 0.35rem;
  }
  .cp-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .cp-dots span.r {
    background: #ff5f57;
  }
  .cp-dots span.y {
    background: #febc2e;
  }
  .cp-dots span.g {
    background: #28c840;
  }
  .cp-title {
    font-size: 0.65rem;
    color: var(--muted);
    flex: 1;
    margin-left: 0.3rem;
  }

  .model-toggle {
    display: flex;
    gap: 0.35rem;
  }
  .mtb {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 3px;
    cursor: pointer;
    border: 1px solid var(--border2);
    background: var(--bg);
    color: var(--muted);
    transition: all 0.15s;
  }
  .mtb.active {
    border-color: var(--acid);
    color: var(--acid);
    background: rgba(200, 255, 87, 0.07);
  }

  .canvas-wrap {
    position: relative;
  }
  #drawCanvas {
    width: 100%;
    aspect-ratio: 1;
    display: block;
    background: #000;
    cursor: crosshair;
    touch-action: none;
  }
  .canvas-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.15);
    pointer-events: none;
    text-align: center;
    transition: opacity 0.3s;
  }
  .canvas-hint.hidden {
    opacity: 0;
  }

  .canvas-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
  }
  .cf-clear {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid var(--border2);
    background: var(--bg);
    color: var(--muted);
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .cf-clear:hover {
    border-color: var(--red);
    color: var(--red);
  }
  .cf-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    color: var(--muted);
    flex: 1;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-dot.idle {
    background: var(--muted);
  }
  .status-dot.predicting {
    background: var(--amber);
    animation: pulse 0.8s ease infinite;
  }
  .status-dot.done {
    background: var(--acid);
  }
  .status-dot.error {
    background: var(--red);
  }

  /* RESULT PANEL */
  .result-panel {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .pred-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .pred-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(200, 255, 87, 0.05),
      transparent 60%
    );
    pointer-events: none;
  }
  .pc-label {
    font-size: 0.58rem;
    color: var(--muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .pc-digit {
    font-family: "Bebas Neue", sans-serif;
    font-size: 5rem;
    line-height: 1;
    color: var(--acid);
    margin-bottom: 0.5rem;
  }
  .pc-khmer {
    font-size: 3rem;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 0.75rem;
    font-family: "Kantumruy Pro", serif;
  }
  .pc-conf {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }
  .pc-model {
    font-size: 0.6rem;
    color: var(--muted);
    opacity: 0.6;
  }

  /* PROB PANEL */
  .prob-panel {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 10px;
    overflow: hidden;
  }
  .pp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.1rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.6rem;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.02);
  }
  .pp-badge {
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
  }
  .pp-badge.active {
    color: var(--acid);
    border-color: rgba(200, 255, 87, 0.3);
  }

  .pp-bars {
    padding: 0.85rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .pb-row {
    display: grid;
    grid-template-columns: 24px 16px 1fr 36px;
    align-items: center;
    gap: 0.5rem;
  }
  .pb-row.highlight .pb-fill {
    background: var(--acid) !important;
  }
  .pb-row.highlight .pb-kh,
  .pb-row.highlight .pb-num {
    color: var(--acid);
  }

  .pb-kh {
    font-size: 1.1rem;
    color: var(--muted);
    font-family: "Kantumruy Pro", serif;
    text-align: center;
  }
  .pb-num {
    font-size: 0.55rem;
    color: var(--muted);
  }
  .pb-track {
    height: 5px;
    background: var(--border);
    border-radius: 3px;
    overflow: hidden;
  }
  .pb-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--muted);
    width: 0;
    transition:
      width 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.3s;
  }
  .pb-pct {
    font-size: 0.58rem;
    color: var(--muted);
    text-align: right;
  }

  /* API INFO */
  .api-info {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .ai-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    color: var(--muted);
    flex-shrink: 0;
  }
  .ai-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--acid);
    animation: pulse 2s ease infinite;
    flex-shrink: 0;
  }
  .ai-url {
    font-size: 0.6rem;
    color: var(--acid);
    flex: 1;
    word-break: break-all;
  }
  .ai-links {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }
  .ai-link {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ai-link:hover {
    color: var(--acid);
  }

  /* reveal */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }
  .reveal.on {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  // ── Canvas setup ──────────────────────────────────────────────
  const canvas = document.getElementById("drawCanvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;
  const hint = document.getElementById("canvasHint")!;
  const statusDot = document.querySelector(".status-dot") as HTMLElement;
  const statusTxt = document.getElementById("statusText")!;
  const predDigit = document.getElementById("predDigit")!;
  const predKhmer = document.getElementById("predKhmer")!;
  const predConf = document.getElementById("predConf")!;
  const predModel = document.getElementById("predModel")!;
  const ppBadge = document.getElementById("ppBadge")!;

  const API = "https://mondolreal-khmer-digit-api.hf.space";
  const KHMER = ["០", "១", "២", "៣", "៤", "៥", "៦", "៧", "៨", "៩"];

  let isDrawing = false;
  let activeModel = "lenet";
  let predictTimer: ReturnType<typeof setTimeout> | null = null;

  // Init black canvas
  function initCanvas() {
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }
  initCanvas();

  function isEmpty() {
    const d = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
    for (let i = 0; i < d.length; i += 4) if (d[i] > 10) return false;
    return true;
  }

  function getPos(e: MouseEvent | Touch) {
    const rect = canvas.getBoundingClientRect();
    return {
      x: (e.clientX - rect.left) * (canvas.width / rect.width),
      y: (e.clientY - rect.top) * (canvas.height / rect.height),
    };
  }

  function startDraw(e: MouseEvent | Touch) {
    isDrawing = true;
    hint.classList.add("hidden");
    ctx.strokeStyle = "#fff";
    ctx.lineWidth = 18;
    ctx.lineJoin = "round";
    ctx.lineCap = "round";
    ctx.beginPath();
    const p = getPos(e);
    ctx.moveTo(p.x, p.y);
  }
  function moveDraw(e: MouseEvent | Touch) {
    if (!isDrawing) return;
    const p = getPos(e);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
    ctx.moveTo(p.x, p.y);
  }
  function endDraw() {
    if (!isDrawing) return;
    isDrawing = false;
    if (!isEmpty()) {
      if (predictTimer) clearTimeout(predictTimer);
      predictTimer = setTimeout(() => predict(activeModel), 300);
    }
  }

  canvas.addEventListener("mousedown", (e) => startDraw(e));
  canvas.addEventListener("mousemove", (e) => moveDraw(e));
  canvas.addEventListener("mouseup", endDraw);
  canvas.addEventListener("mouseleave", endDraw);
  canvas.addEventListener(
    "touchstart",
    (e) => {
      e.preventDefault();
      startDraw(e.touches[0]);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchmove",
    (e) => {
      e.preventDefault();
      moveDraw(e.touches[0]);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchend",
    (e) => {
      e.preventDefault();
      endDraw();
    },
    { passive: false },
  );

  // ── Model toggle ─────────────────────────────────────────────
  document.querySelectorAll(".mtb").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".mtb")
        .forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeModel = (btn as HTMLElement).dataset.model!;
      if (!isEmpty()) predict(activeModel);
    });
  });

  // ── Clear ────────────────────────────────────────────────────
  document.getElementById("clearBtn")!.addEventListener("click", () => {
    initCanvas();
    hint.classList.remove("hidden");
    predDigit.textContent = "–";
    predKhmer.textContent = "?";
    predConf.textContent = "— % confident";
    predModel.textContent = "model: —";
    ppBadge.textContent = "waiting";
    ppBadge.classList.remove("active");
    setStatus("idle", "Ready — draw to predict");
    resetBars();
  });

  function setStatus(state: string, msg: string) {
    statusDot.className = `status-dot ${state}`;
    statusTxt.textContent = msg;
  }

  function resetBars() {
    document
      .querySelectorAll(".pb-fill")
      .forEach((el) => ((el as HTMLElement).style.width = "0%"));
    document
      .querySelectorAll(".pb-pct")
      .forEach((el) => (el.textContent = "—"));
    document
      .querySelectorAll(".pb-row")
      .forEach((el) => el.classList.remove("highlight"));
  }

  // ── Predict ──────────────────────────────────────────────────
  async function predict(model: string) {
    if (isEmpty()) return;
    setStatus(
      "predicting",
      `Predicting with ${model === "lenet" ? "LeNet" : "ResNet"}…`,
    );

    canvas.toBlob(async (blob) => {
      if (!blob) return;
      const fd = new FormData();
      fd.append("file", blob, "digit.png");

      try {
        const res = await fetch(`${API}/predict/${model}`, {
          method: "POST",
          body: fd,
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        updateUI(data);
        setStatus("done", "Prediction complete");
      } catch (err) {
        console.error(err);
        setStatus("error", "API error — check connection");
      }
    });
  }

  function updateUI(data: {
    digit: number;
    khmer: string;
    confidence: number;
    probabilities: number[];
    model: string;
  }) {
    predDigit.textContent = String(data.digit);
    predKhmer.textContent = data.khmer;
    predConf.textContent = `${Math.round(data.confidence * 100)}% confident`;
    predModel.textContent = `model: ${data.model}`;

    ppBadge.textContent = data.model;
    ppBadge.classList.add("active");

    resetBars();
    data.probabilities.forEach((p, i) => {
      const pct = Math.round(p * 100);
      const fill = document.querySelector(
        `.pb-fill[data-idx="${i}"]`,
      ) as HTMLElement;
      const lbl = document.querySelector(`.pb-pct[data-idx="${i}"]`);
      const row = document.querySelector(`.pb-row[data-idx="${i}"]`);
      if (fill) fill.style.width = `${pct}%`;
      if (lbl) lbl.textContent = `${pct}%`;
      if (i === data.digit && row) row.classList.add("highlight");
    });
  }

  // Scroll reveal
  const io = new IntersectionObserver(
    (es) =>
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("on");
          io.unobserve(e.target);
        }
      }),
    { threshold: 0.06 },
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
</script>
